# Required — MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shopez?retryWrites=true&w=majority&appName=Cluster0

# Optional — Server port (defaults to 5000)
PORT=5000

# Required — JWT secret key (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Optional — Node environment
NODE_ENV=development
